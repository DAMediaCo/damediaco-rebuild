---
import { business, navLinks } from '../data/site';

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container-shell header-bar">
    <a class="brand-mark" href="/">
      <img src="/chillers/logo.png" alt={`${business.name} logo`} width="64" height="64" />
      <span>
        <strong>{business.shortName}</strong>
        <em>Pompano Beach, FL</em>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Primary">
      {
        navLinks.map((link) => (
          <a class={currentPath === link.href ? 'is-active' : ''} href={link.href}>
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="header-actions">
      <a class="button-secondary header-cta" href={business.googleMapsUrl} target="_blank" rel="noreferrer">
        Directions
      </a>
      <button class="nav-toggle" type="button" data-nav-toggle aria-label="Open navigation">
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div class="mobile-panel" aria-label="Mobile navigation">
    <div class="mobile-panel-inner">
      <div class="mobile-panel-top">
        <span class="eyebrow">Navigate</span>
        <button class="mobile-close" type="button" data-nav-close aria-label="Close navigation">
          Close
        </button>
      </div>

      <nav class="mobile-nav" aria-label="Mobile primary">
        {
          navLinks.map((link) => (
            <a class={currentPath === link.href ? 'is-active' : ''} href={link.href} data-nav-close>
              {link.label}
            </a>
          ))
        }
      </nav>

      <div class="mobile-links">
        <a class="button-primary" href={business.menuUrl} target="_blank" rel="noreferrer">
          Full Menu
        </a>
        <a class="button-secondary" href={business.phoneHref}>
          Call {business.phone}
        </a>
      </div>
    </div>
  </div>
</header>
