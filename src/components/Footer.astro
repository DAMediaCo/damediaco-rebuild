---
import { business, navLinks } from '../data/site';
---

<footer class="site-footer">
  <div class="container-shell footer-grid">
    <div>
      <p class="eyebrow">Chillers Kava and Coffee</p>
      <h2>Open since {business.openedSince} in Pompano Beach.</h2>
      <p class="footer-note">
        Coffee, kava, elixirs, late-night hours, and the current menu in one place.
      </p>
      <div class="action-row footer-actions">
        <a class="button-primary" href={business.googleMapsUrl} target="_blank" rel="noreferrer">
          Directions
        </a>
        <a class="button-secondary" href={business.phoneHref}>
          Call {business.phone}
        </a>
      </div>
    </div>

    <div class="footer-links">
      <div>
        <h3>Explore</h3>
        <ul>
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3>Visit</h3>
        <ul>
          <li>{business.addressLine1}</li>
          <li>{business.addressLine2}</li>
          <li>
            <a href={business.phoneHref}>{business.phone}</a>
          </li>
          <li>
            <a href={business.googleMapsUrl} target="_blank" rel="noreferrer">
              Open in Google Maps
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3>Social</h3>
        <ul>
          <li>
            <a href={business.instagram} target="_blank" rel="noreferrer">
              Instagram
            </a>
          </li>
          <li>
            <a href={business.facebook} target="_blank" rel="noreferrer">
              Facebook
            </a>
          </li>
          <li>
            <a href={business.linktree} target="_blank" rel="noreferrer">
              Linktree
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</footer>
